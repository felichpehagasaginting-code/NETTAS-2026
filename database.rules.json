{
  "rules": {
    "global_clicks": {
      ".read": "auth != null",
      ".write": "auth != null && newData.isNumber() && newData.val() >= 0"
    },
    "counter_shards": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "config": {
      ".read": "auth != null",
      "target_clicks": {
        ".write": "auth != null && newData.isNumber() && newData.val() >= 1 && newData.val() <= 999999"
      },
      "theme": {
        ".write": "auth != null && newData.isString()"
      },
      "bgm_url": {
        ".write": "auth != null && newData.isString()"
      }
    },
    "presence": {
      ".read": "auth != null",
      "$node_id": {
        ".write": "auth != null && newData.isString()",
        ".validate": "newData.isString()"
      }
    },
    "users": {
      ".indexOn": ["clicks"],
      "$node_id": {
        ".read": "auth != null",
        ".write": "auth != null && newData.hasChildren(['name', 'clicks']) && newData.child('clicks').isNumber() && newData.child('name').isString()"
      }
    },
    "admins": {
      ".read": "auth != null",
      ".write": "auth != null"
    }
  }
}
