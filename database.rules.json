{
  "rules": {
    "global_clicks": {
      ".read": "auth != null",
      ".write": "auth != null && newData.isNumber() && newData.val() >= 0"
    },
    "counter_shards": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "presence": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$uid": {
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['online', 'connectedAt'])"
      }
    },
    "active_clicks": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$uid": {
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['lastTap'])"
      }
    },
    "config": {
      ".read": "auth != null",
      "target_clicks": {
        ".write": "auth != null && newData.isNumber() && newData.val() >= 1 && newData.val() <= 999999"
      },
      "theme": {
        ".write": "auth != null && newData.isString()"
      },
      "bgm_url": {
        ".write": "auth != null && newData.isString()"
      },
      "victory_bgm_url": {
        ".write": "auth != null && newData.isString()"
      },
      "youtube_video_id": {
        ".write": "auth != null && newData.isString()"
      }
    }
  }
}
