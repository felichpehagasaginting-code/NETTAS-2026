{
  "rules": {

    ".read": true,

    "global_clicks": {
      ".read": true,
      ".write": "newData.isNumber() && newData.val() >= 0"
    },

    "config": {
      ".read": true,
      "target_clicks": {
        ".write": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 999999"
      }
    },

    "presence": {
      ".read": true,
      "$node_id": {
        ".write": "(!newData.exists() || (newData.val() === true && $node_id.length > 0))"
      }
    },

    "users": {
      ".indexOn": ["clicks"],
      "$node_id": {
        ".read": true,
        ".write": "!data.exists() || (newData.child('clicks').isNumber() && newData.child('name').isString() && root.child('user_pins/' + $node_id).val() === newData.child('pinHash').val())"
      }
    },

    "user_pins": {
      ".read": false,
      "$node_id": {
        ".write": "!data.exists() || data.val() === newData.val()"
      }
    }

  }
}
