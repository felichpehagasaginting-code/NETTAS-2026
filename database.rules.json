{
  "rules": {

    ".read": true,

    "global_clicks": {
      ".read": true,
      ".write": "newData.isNumber() && newData.val() >= 0"
    },

    "config": {
      ".read": true,
      "target_clicks": {
        ".write": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 999999"
      },
      "theme": {
        ".write": "newData.isString()"
      },
      "bgm_url": {
        ".write": "newData.isString()"
      }
    },

    "presence": {
      ".read": true,
      "$node_id": {
        ".write": "(!newData.exists() || (newData.val() === true && $node_id.length > 0))"
      }
    },

    "users": {
      ".indexOn": ["clicks"],
      "$node_id": {
        ".read": true,
        ".write": "!newData.exists() || (newData.child('clicks').isNumber() && newData.child('name').isString())"
      }
    }

  }
}
